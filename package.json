{
   "name": "vms-api",
   "version": "0.0.1",
   "description": "",
   "author": "",
   "private": true,
   "license": "UNLICENSED",
   "scripts": {
      "build": "nest build",
      "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
      "start": "nest start",
      "start:dev": "nest start --watch",
      "start:debug": "nest start --debug --watch",
      "start:prod": "node dist/src/main",
      "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
      "test": "jest",
      "test:watch": "jest --watch",
      "test:cov": "jest --coverage",
      "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
      "test:e2e": "jest --config ./test/jest-e2e.json",
      "migration:generate": "ts-node --project tsconfig.typeorm.json ./node_modules/typeorm/cli.js migration:generate ./src/data/migrations/BI_$NAME -d ./src/typeorm.config.ts",
      "migration:run": "ts-node --project tsconfig.typeorm.json ./node_modules/typeorm/cli.js migration:run -d ./src/typeorm.config.ts",
      "migration:revert": "ts-node --project tsconfig.typeorm.json ./node_modules/typeorm/cli.js migration:revert -d ./src/typeorm.config.ts"
   },
   "dependencies": {
      "@aws-sdk/client-s3": "^3.1015.0",
      "@aws-sdk/s3-request-presigner": "^3.1015.0",
      "@google-cloud/storage": "^7.18.0",
      "@nestjs-modules/mailer": "^2.3.4",
      "@nestjs/common": "^10.4.20",
      "@nestjs/config": "^4.0.0",
      "@nestjs/core": "^10.4.20",
      "@nestjs/jwt": "^10.2.0",
      "@nestjs/passport": "^10.0.3",
      "@nestjs/platform-express": "^10.4.20",
      "@nestjs/platform-socket.io": "^10.4.22",
      "@nestjs/swagger": "^7.4.2",
      "@nestjs/throttler": "^6.5.0",
      "@nestjs/typeorm": "^10.0.2",
      "@nestjs/websockets": "^10.4.22",
      "bcrypt": "^5.1.1",
      "class-transformer": "^0.5.1",
      "class-validator": "^0.14.1",
      "cookie": "^1.1.1",
      "cookie-parser": "^1.4.7",
      "firebase-admin": "^13.8.0",
      "google-auth-library": "^10.6.2",
      "googleapis": "^171.4.0",
      "nodemailer": "^8.0.5",
      "passport": "^0.7.0",
      "passport-jwt": "^4.0.1",
      "pg": "^8.13.1",
      "razorpay": "^2.9.6",
      "reflect-metadata": "^0.1.13",
      "resend": "^6.11.0",
      "rxjs": "^7.8.1",
      "socket.io": "^4.8.3",
      "typeorm": "^0.3.20",
      "uuid": "^13.0.0"
   },
   "devDependencies": {
      "@nestjs/cli": "^11.0.14",
      "@nestjs/schematics": "^11.0.9",
      "@nestjs/testing": "^10.4.20",
      "@types/bcrypt": "^5.0.2",
      "@types/cookie-parser": "^1.4.10",
      "@types/express": "^4.17.21",
      "@types/jest": "^29.5.12",
      "@types/node": "^20.14.0",
      "@types/nodemailer": "^8.0.0",
      "@types/passport-jwt": "^4.0.1",
      "@types/supertest": "^6.0.2",
      "@typescript-eslint/eslint-plugin": "^6.21.0",
      "@typescript-eslint/parser": "^6.21.0",
      "eslint": "^8.57.0",
      "eslint-config-prettier": "^9.1.0",
      "eslint-plugin-prettier": "^5.2.0",
      "jest": "^29.7.0",
      "prettier": "^3.3.3",
      "source-map-support": "^0.5.21",
      "supertest": "^7.0.0",
      "ts-jest": "^29.2.0",
      "ts-loader": "^9.5.1",
      "ts-node": "^10.9.2",
      "tsconfig-paths": "^4.2.0",
      "typescript": "^5.5.4"
   },
   "jest": {
      "moduleFileExtensions": [
         "js",
         "json",
         "ts"
      ],
      "rootDir": "src",
      "testRegex": ".*\\.spec\\.ts$",
      "transform": {
         "^.+\\.(t|j)s$": "ts-jest"
      },
      "collectCoverageFrom": [
         "**/*.(t|j)s"
      ],
      "coverageDirectory": "../coverage",
      "testEnvironment": "node"
   },
   "resolutions": {
      "string-width": "^4.2.3"
   }
}
